*.dcu
*.exe
*.dll
*.bpl
*.dcp
*.so
*.dylib
*.map
*.drc
*.rsm
*.tds
*.dbg

# Build / history folders
__history/
__recovery/
dcu/
bin/
lib/
Win32/
Win64/
Debug/
Release/
Android/
Android64/
iOSDevice64/
